{
  "name": "rate-limiting-demo",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "cd frontend && bun run dev",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:backend": "cd backend && bun run dev",
    "dev:all": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    "server": "bun run backend/index.ts",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "cd backend && bun run build",
    "build:frontend": "cd frontend && bun run build",
    "test": "bun run backend/test-algorithms.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
